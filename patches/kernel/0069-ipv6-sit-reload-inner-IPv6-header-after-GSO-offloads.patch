diff --git a/net/ipv6/sit.c b/net/ipv6/sit.c
index 12496ba1b7d4d3cf8127fdda5c157f73f8770b48..d73e8a0289bf65f96e33c3a3e69e594ed36d0d30 100644
--- a/net/ipv6/sit.c
+++ b/net/ipv6/sit.c
@@ -968,6 +968,7 @@ static netdev_tx_t ipip6_tunnel_xmit(struct sk_buff *skb,
 		ip_rt_put(rt);
 		goto tx_error;
 	}
+	iph6 = ipv6_hdr(skb);
 
 	if (df) {
 		mtu = dst_mtu(&rt->dst) - t_hlen;
